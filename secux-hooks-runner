#!/bin/bash

# Overwrite the contents of /etc/lsb-release
Lsb_release() {
    local file=/etc/lsb-release
    if [ ! -f "$file" ]; then
        echo "lsb-release file not found. Exiting..."
        exit 0
    fi

    cat <<EOF > $file
DISTRIB_ID="Secux Linux"
DISTRIB_RELEASE="rolling"
DISTRIB_DESCRIPTION="Secux Linux"
EOF
}

# Overwrite the contents of /etc/os-release
Os_release() {
    local file=/usr/lib/os-release
    if [ ! -f "$file" ]; then
        echo "os-release file not found. Exiting..."
        exit 0
    fi

    cat <<EOF > $file
NAME="Secux Linux"
PRETTY_NAME="Secux Linux"
BUILD_ID=rolling
HOME_URL="https://github.com/kolbanidze/secux-iso"
LOGO=SecuxLinux
EOF
}

# Replace "Arch" with "Secux" in issue files
Issues() {
    sed -i 's|Arch|Secux|g' /etc/issue /usr/share/factory/etc/issue
}

# Modify mkinitcpio presets and create systemd-boot entries
Mkinitcpio_presets() {
    local preset_dir="/etc/mkinitcpio.d"
    local efi_mount="/efi"
    local uki_dir="${efi_mount}/EFI/secux"
    local loader_dir="${efi_mount}/loader/entries"
    
    # Check if preset directory exists
    if [ ! -d "$preset_dir" ]; then
        return
    fi

    # Ensure target directories exist
    mkdir -p "$uki_dir"
    mkdir -p "$loader_dir"

    # Loop through all preset files
    for file in "$preset_dir"/*.preset; do
        [ -e "$file" ] || continue
        
        # Extract kernel name (e.g., 'linux' from 'linux.preset')
        local kver=$(basename "$file" .preset)

        # --- 1. Modify Preset File ---

        # Set PRESETS to only 'default'
        if grep -q "PRESETS=" "$file"; then
            sed -i "s|^#\?PRESETS=.*|PRESETS=('default')|" "$file"
        else
            echo "PRESETS=('default')" >> "$file"
        fi

        # Configure default_uki path
        # Changes path to /efi/EFI/secux/secux-<kernel>.efi
        local uki_path="${uki_dir}/secux-${kver}.efi"
        
        if grep -q "default_uki=" "$file"; then
            sed -i "s|^#\?default_uki=.*|default_uki=\"${uki_path}\"|" "$file"
        else
            echo "default_uki=\"${uki_path}\"" >> "$file"
        fi

        # Ensure default_options is empty
        if grep -q "default_options=" "$file"; then
            sed -i 's|^#\?default_options=.*|default_options=""|' "$file"
        else
            echo 'default_options=""' >> "$file"
        fi

        # Comment out standard images and configs (force UKI)
        sed -i 's|^default_image|#default_image|' "$file"
        sed -i 's|^default_config|#default_config|' "$file"
        sed -i 's|^fallback_|#fallback_|' "$file"

        # --- 2. Create systemd-boot entry ---
        
        # Entry file: /efi/loader/entries/secux-<kernel>.conf
        # Path for loader relative to ESP root: /EFI/secux/secux-<kernel>.efi
        
        local entry_file="${loader_dir}/secux-${kver}.conf"
        local relative_uki_path="/EFI/secux/secux-${kver}.efi"

        cat <<EOF > "$entry_file"
title Secux Linux (${kver})
efi ${relative_uki_path}
EOF

    done
}

# Main function
Main() {
    local hookname="$1"
    
    case "$hookname" in
        os-release)  Os_release ;;
        lsb-release) Lsb_release ;;
        mkinitcpio)  Mkinitcpio_presets ;;
        "")          Os_release
                     Lsb_release
                     Issues
                     Mkinitcpio_presets
                     ;;
        *)           echo "Invalid argument. Use 'os-release', 'lsb-release', 'mkinitcpio' or nothing." ;;
    esac
}

Main "$@"