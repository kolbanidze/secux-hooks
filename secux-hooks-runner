#!/bin/bash

# Overwrite the contents of /etc/lsb-release
Lsb_release() {
    local file=/etc/lsb-release
    if [ ! -f "$file" ]; then
        echo "lsb-release file not found. Exiting..."
        exit 0
    fi

    cat <<EOF > $file
DISTRIB_ID="Secux Linux"
DISTRIB_RELEASE="rolling"
DISTRIB_DESCRIPTION="Secux Linux"
EOF
}

# Overwrite the contents of /etc/os-release
Os_release() {
    local file=/usr/lib/os-release
    if [ ! -f "$file" ]; then
        echo "os-release file not found. Exiting..."
        exit 0
    fi

    cat <<EOF > $file
NAME="Secux Linux"
PRETTY_NAME="Secux Linux"
BUILD_ID=rolling
HOME_URL="https://github.com/kolbanidze/secux-iso"
LOGO=SecuxLinux
EOF
}

# Replace "Arch" with "Secux" in issue files
Issues() {
    sed -i 's|Arch|Secux|g' /etc/issue /usr/share/factory/etc/issue
}

# Modify mkinitcpio presets and create systemd-boot entries
Mkinitcpio_presets() {
    local efi_mount="/efi"
    local uki_dir="${efi_mount}/EFI/secux"
    local loader_dir="${efi_mount}/loader/entries"
    local hook_preset="/usr/share/mkinitcpio/hook.preset"
    
    # Check if hook.preset exists
    if [ ! -f "$hook_preset" ]; then
        return
    fi

    # Ensure target directories exist
    mkdir -p "$uki_dir"
    mkdir -p "$loader_dir"
    
    # Modify /usr/share/mkinitcpio/hook.preset
    # Remove fallback preset line
    sed -i '/#PRESETS=.*fallback/d' "$hook_preset"
    
    # Comment out default_image
    sed -i 's/^default_image=/#default_image=/' "$hook_preset"
    
    # Uncomment and change default_uki path
    sed -i 's|^#default_uki="/efi/EFI/Linux/arch-%PKGBASE%.efi"|default_uki="/efi/EFI/secux/secux-%PKGBASE%.efi"|' "$hook_preset"
    
    # Uncomment and clear default_options
    sed -i 's|^#default_options="--splash.*"|default_options=""|' "$hook_preset"
    
    # Change fallback_uki path (keep commented)
    sed -i 's|^#fallback_uki="/efi/EFI/Linux/arch-%PKGBASE%-fallback.efi"|#fallback_uki="/efi/EFI/secux/secux-%PKGBASE%-fallback.efi"|' "$hook_preset"
    
    # Create loader entry
    local entry_file="${loader_dir}/secux-${kver}.conf"
    local relative_uki_path="/EFI/secux/secux-${kver}.efi"

    cat <<EOF > "$entry_file"
title Secux Linux (${kver})
efi ${relative_uki_path}
EOF
}

# Main function
Main() {
    local hookname="$1"
    
    case "$hookname" in
        os-release)  Os_release ;;
        lsb-release) Lsb_release ;;
        mkinitcpio)  Mkinitcpio_presets ;;
        "")          Os_release
                     Lsb_release
                     Issues
                     Mkinitcpio_presets
                     ;;
        *)           echo "Invalid argument. Use 'os-release', 'lsb-release', 'mkinitcpio' or nothing." ;;
    esac
}

Main "$@"